# Gavel-AI Environment Configuration
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env to git (already in .gitignore)

# Provider API Keys
# ==================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI (GPT)
OPENAI_API_KEY=sk-your-openai-key-here

# Google (Gemini) - Optional
GOOGLE_API_KEY=your-google-api-key-here

# Vertex AI - Optional (if using Vertex instead of standard Anthropic)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# Ollama - Optional (local models)
OLLAMA_BASE_URL=http://localhost:11434

# Gavel Runtime Configuration
# ============================

# Optional: Override default eval root location
# GAVEL_ROOT=/custom/path/to/.gavel

# Optional: DeepEval judges may require OpenAI for certain metrics
# (Uses OPENAI_API_KEY above)
